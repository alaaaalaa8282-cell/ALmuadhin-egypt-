<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1a1a2e"
    android:padding="24dp">

    <!-- صورة الخلفية بشفافية -->
<ImageView
    android:id="@+id/father_bg"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:src="@drawable/father_bg"
    android:scaleType="centerCrop"
    android:alpha="0.18"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>
   
    <!-- النجمة أو الهلال -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🕌"
        android:textSize="72sp"
        android:layout_marginBottom="16dp"/>

    <!-- حان وقت الصلاة -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="حان وقت الصلاة"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-medium"/>

    <!-- اسم الصلاة -->
    <TextView
        android:id="@+id/tvPrayerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="42sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- الله أكبر -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الله أكبر"
        android:textColor="#A0C4FF"
        android:textSize="20sp"
        android:layout_marginBottom="48dp"/>

    <!-- زرار إغلاق الأذان -->
    <Button
        android:id="@+id/btnDismiss"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="إغلاق الأذان"
        android:textSize="18sp"
        android:backgroundTint="#FFD700"
        android:textColor="#1a1a2e"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

</LinearLayout>
